# Copie este arquivo para .env e preencha os valores

# Porta do servidor (Replit usa 3000 por padrão)
PORT=3000

# Chave secreta para sessões (troque para algo seguro em produção!)
SESSION_SECRET=troque-esta-chave-por-algo-muito-seguro-123

# Ambiente (development ou production)
NODE_ENV=development
