<%- include('partials/header', {pageTitle: 'Dashboard', activeMenu: 'dashboard'}) %>

<div class="page-header">
  <h1><i class="fas fa-tachometer-alt"></i> Dashboard</h1>
  <p>Bem-vindo ao painel administrativo</p>
</div>

<!-- Stats Cards -->
<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-icon" style="background: #3b82f6;">
      <i class="fas fa-box"></i>
    </div>
    <div class="stat-info">
      <span class="stat-value"><%= totalProdutos %></span>
      <span class="stat-label">Produtos Ativos</span>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background: #10b981;">
      <i class="fas fa-tags"></i>
    </div>
    <div class="stat-info">
      <span class="stat-value"><%= totalCategorias %></span>
      <span class="stat-label">Categorias</span>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background: #f59e0b;">
      <i class="fas fa-fire"></i>
    </div>
    <div class="stat-info">
      <span class="stat-value"><%= produtosDestaque %></span>
      <span class="stat-label">Em Destaque</span>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background: var(--primary);">
      <i class="fas fa-store"></i>
    </div>
    <div class="stat-info">
      <span class="stat-value">Ativa</span>
      <span class="stat-label">Status da Loja</span>
    </div>
  </div>
</div>

<!-- Quick Actions -->
<div class="dashboard-grid">
  <div class="card">
    <div class="card-header">
      <h2><i class="fas fa-bolt"></i> Ações Rápidas</h2>
    </div>
    <div class="quick-actions">
      <a href="/admin/produtos/novo" class="quick-btn">
        <i class="fas fa-plus"></i>
        <span>Novo Produto</span>
      </a>
      <a href="/admin/categorias" class="quick-btn">
        <i class="fas fa-tags"></i>
        <span>Categorias</span>
      </a>
      <a href="/admin/configuracoes" class="quick-btn">
        <i class="fas fa-palette"></i>
        <span>Aparência</span>
      </a>
      <a href="/" target="_blank" class="quick-btn">
        <i class="fas fa-eye"></i>
        <span>Ver Loja</span>
      </a>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <h2><i class="fas fa-clock"></i> Últimos Produtos</h2>
      <a href="/admin/produtos" class="link-sm">Ver todos</a>
    </div>
    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>Nome</th>
            <th>Preço</th>
            <th>Categoria</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% ultimosProdutos.forEach(p => { %>
          <tr>
            <td>
              <div class="td-produto">
                <img src="<%= p.imagem_url || '/public/images/no-image.svg' %>" alt="">
                <span><%= p.nome %></span>
              </div>
            </td>
            <td>R$ <%= p.preco.toFixed(2).replace('.',',') %></td>
            <td><%= p.categoria_nome || '—' %></td>
            <td>
              <a href="/admin/produtos/<%= p.id %>/editar" class="btn-icon" title="Editar"><i class="fas fa-edit"></i></a>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
